{
  "name": "@aiusage/worker",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/ennann/aiusage.git",
    "directory": "packages/worker"
  },
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @aiusage/dashboard build && wrangler dev",
    "build": "tsc --noEmit",
    "deploy": "pnpm --filter @aiusage/dashboard build && wrangler deploy",
    "lint": "tsc --noEmit",
    "types": "wrangler types",
    "test": "echo 'no tests yet'",
    "db:migrate:local": "wrangler d1 execute aiusage-db --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute aiusage-db --remote --file=migrations/0001_init.sql"
  },
  "dependencies": {
    "@aiusage/dashboard": "workspace:*",
    "@aiusage/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5",
    "wrangler": "^4.80.0"
  }
}
