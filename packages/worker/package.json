{
  "name": "@aiusage/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "lint": "tsc --noEmit",
    "types": "wrangler types",
    "test": "echo 'no tests yet'",
    "db:migrate:local": "wrangler d1 execute aiusage-db --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute aiusage-db --remote --file=migrations/0001_init.sql"
  },
  "dependencies": {
    "@aiusage/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5",
    "wrangler": "^4"
  }
}
